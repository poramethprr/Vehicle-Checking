generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  MAID
}

enum CleaningIssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum InspectionStatus {
  NORMAL
  ABNORMAL
}

enum VehicleStatus {
  ACTIVE
  IN_USE
  MAINTENANCE
  INACTIVE
}

enum BookingStatus {
  CHECKED_OUT
  RETURNED
  CANCELLED
}

enum RenewalType {
  PRB
  TAX
  INS
  GAS
}

enum RepairStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  id              Int          @id @default(autoincrement())
  username        String       @unique
  displayName     String?
  phone           String       @unique
  password        String?
  role            Role         @default(STAFF)
  licenseNumber   String?
  licenseExpiry   DateTime?
  licensePhoto    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  microsoftId         String?  @unique
  microsoftEmail      String?  @unique
  requireMicrosoftSSO Boolean  @default(false)

  @@index([microsoftEmail])

  inspections          Inspection[]
  activityLogs         ActivityLog[]
  bookingsRequested    Booking[]          @relation("BookingRequester")
  bookingsDriven       Booking[]          @relation("BookingDriver")
  returnRequests       Booking[]          @relation("BookingReturnRequester")
  renewals             VehicleRenewal[]
  repairsRequested     RepairRequest[]    @relation("RepairRequester")
  repairsApproved      RepairRequest[]    @relation("RepairApprover")
  fuelLogs             FuelLog[]
  accidents            AccidentReport[]
  cleaningLogs         CleaningLog[]
  cleaningIssues       CleaningIssue[]    @relation("IssueReporter")
  issuesResolved       CleaningIssue[]    @relation("IssueResolver")
}

model Vehicle {
  id              Int            @id @default(autoincrement())
  type            String
  licensePlate    String         @unique
  registrationBookNumber String?
  chassisNumber   String?
  engineNumber    String?
  currentMileage  Float?
  nextMileage     Float?
  overMileage     Float?
  status          VehicleStatus  @default(ACTIVE)
  note            String?

  // พ.ร.บ.
  prbDate               DateTime?
  prbLmg                Boolean        @default(false)
  prbViriya             Boolean        @default(false)
  prbAkney              Boolean        @default(false)
  prbThewet             Boolean        @default(false)
  prbInsurance          Boolean        @default(false)
  prbBangkokInsurance   Boolean        @default(false)
  prbTaxDate            DateTime?
  prbThirdParty         Boolean        @default(false)
  prbExpiry             DateTime?
  prbContact            String?

  // รอบต่อประกัน
  insLmg                Boolean        @default(false)
  insViriya             Boolean        @default(false)
  insThaiInsurance      Boolean        @default(false)
  insInsurance          Boolean        @default(false)
  insAkney              Boolean        @default(false)
  insThewet             Boolean        @default(false)
  insBangkokInsurance   Boolean        @default(false)
  insDate               DateTime?
  insTaxDate            DateTime?
  insExpiry             DateTime?
  insContact            String?

  taxRenewalDate  DateTime?

  // แก๊ส
  gasNgv          Boolean   @default(false)
  gasLpg          Boolean   @default(false)
  gasExpiry       DateTime?
  gasContact      String?

  prbDoc    String?
  taxDoc    String?
  insDoc    String?
  gasDoc    String?

  photo           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  inspections     Inspection[]
  bookings        Booking[]
  renewals        VehicleRenewal[]
  repairs         RepairRequest[]
  fuelLogs        FuelLog[]
  accidents       AccidentReport[]
}

model Booking {
  id              Int            @id @default(autoincrement())
  vehicleId       Int
  requesterId     Int            // คนทำเรื่องเบิก
  driverId        Int            // คนขับ
  status          BookingStatus  @default(CHECKED_OUT)

  // ข้อมูลเบิก (checkout)
  destination     String         // สถานที่ที่ไปใช้รถ
  purpose         String?        // วัตถุประสงค์
  checkoutDate    DateTime       @default(now())
  mileageOut      Float          // เลขไมล์ตอนออก
  mileageOutPhoto String?        // path รูปไมล์ตอนออก

  // ข้อมูลคืน (return)
  returnDate      DateTime?
  mileageIn       Float?         // เลขไมล์ตอนกลับ
  mileageInPhoto  String?        // path รูปไมล์ตอนกลับ
  distance        Float?         // ระยะทาง (คำนวณอัตโนมัติ = mileageIn - mileageOut)
  returnNote      String?        // หมายเหตุตอนคืน

  // ข้อมูลขอคืน (pending return — staff submits, admin approves)
  pendingMileageIn      Float?
  pendingMileageInPhoto String?
  pendingReturnNote     String?
  returnRequestedAt     DateTime?
  returnRequestedById   Int?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  vehicle         Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  requester       User           @relation("BookingRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  driver          User           @relation("BookingDriver", fields: [driverId], references: [id], onDelete: Cascade)
  returnRequester User?          @relation("BookingReturnRequester", fields: [returnRequestedById], references: [id], onDelete: SetNull)
}

model Inspection {
  id              Int               @id @default(autoincrement())
  vehicleId       Int
  userId          Int
  inspectionDate  DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  details         InspectionDetail[]

  @@unique([vehicleId, inspectionDate])
}

model InspectionDetail {
  id            Int              @id @default(autoincrement())
  inspectionId  Int
  itemNumber    Int
  itemName      String
  status        InspectionStatus
  abnormalNote  String?

  inspection    Inspection       @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@unique([inspectionId, itemNumber])
}

model VehicleRenewal {
  id           Int         @id @default(autoincrement())
  vehicleId    Int
  userId       Int
  type         RenewalType
  provider     String?     // บริษัทที่ต่อ (เช่น "วิริยะ, LMG")
  expiryDate   DateTime    // วันหมดอายุใหม่ที่ตั้งไว้
  documentPath String?     // path ของไฟล์แนบ
  note         String?
  createdAt    DateTime    @default(now())

  vehicle      Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RepairRequest {
  id             Int           @id @default(autoincrement())
  vehicleId      Int
  userId         Int
  title          String
  detail         String
  documentPath   String?       // ใบเสนอราคา (รูป หรือ PDF)
  estimatedCost  Float?        // วงเงินประมาณการ (บาท)
  status         RepairStatus  @default(PENDING)
  approvedById   Int?
  approvedAt     DateTime?
  approverNote   String?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  vehicle        Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user           User          @relation("RepairRequester", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy     User?         @relation("RepairApprover", fields: [approvedById], references: [id], onDelete: SetNull)
}

model FuelLog {
  id                 Int      @id @default(autoincrement())
  vehicleId          Int
  userId             Int
  mileageBefore      Float
  mileageAfter       Float?
  liters             Float
  amount             Float
  mileagePhotoBefore String?
  mileagePhotoAfter  String?
  gaugePhotoBefore   String?
  gaugePhotoAfter    String?
  pumpPhoto          String?
  receiptPhoto       String?
  note               String?
  createdAt          DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccidentReport {
  id            Int      @id @default(autoincrement())
  vehicleId     Int
  userId        Int
  location      String
  damagedParts  String
  detail        String?
  photo1        String?
  photo2        String?
  photo3        String?
  photo4        String?
  photo5        String?
  photo6        String?
  note          String?
  createdAt     DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CleaningArea {
  id          Int      @id @default(autoincrement())
  name        String
  location    String?
  description String?
  photo       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs   CleaningLog[]
  issues CleaningIssue[]
}

model CleaningLog {
  id        Int          @id @default(autoincrement())
  areaId    Int
  userId    Int
  photo     String?
  note      String?
  createdAt DateTime     @default(now())

  area CleaningArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CleaningIssue {
  id           Int                  @id @default(autoincrement())
  areaId       Int
  userId       Int
  title        String
  description  String?
  status       CleaningIssueStatus  @default(OPEN)
  photo1       String?
  photo2       String?
  photo3       String?
  resolvedById Int?
  resolvedAt   DateTime?
  resolverNote String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  area     CleaningArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  user     User         @relation("IssueReporter", fields: [userId], references: [id], onDelete: Cascade)
  resolver User?        @relation("IssueResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  action      String
  detail      String
  entityType  String?
  entityId    Int?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
